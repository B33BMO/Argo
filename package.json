{
  "name": "argo",
  "version": "0.1.0",
  "description": "Argo — a TUI for interacting with open-source LLMs with tool calling",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "argo": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "smoke": "tsx src/dev/smoke.tsx"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "glob": "^11.0.0",
    "ink": "^5.0.1",
    "ink-text-input": "^6.0.0",
    "ollama": "^0.5.11",
    "openai": "^4.77.0",
    "react": "^18.3.1",
    "yaml": "^2.6.1"
  },
  "optionalDependencies": {
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "ink-testing-library": "^4.0.0",
    "tsup": "^8.3.5",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18"
  }
}
